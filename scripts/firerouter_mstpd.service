[Unit]
Description=FireRouter MSTP Daemon
After=network.target

[Service]
Type=simple
ExecStart=/bin/bash /home/pi/firerouter/scripts/firerouter_mstpd.sh
Restart=on-failure
RestartSec=5
ExecStartPost=/bin/bash -c 'for i in $(seq 1 50); do ss -xla 2>/dev/null | grep -q mstp_server && exit 0; sleep 0.1; done; exit 1'